# Environment variables for Control Panel Web Panel

# Required: Generate with python -c "from passlib.context import CryptContext; pwd_context = CryptContext(schemes=['bcrypt']); print(pwd_context.hash('your_password'))"
ADMIN_PASSWORD_HASH=

# Secret key for JWT token signing (generate a secure random string)
SECRET_KEY=changeme-in-production-use-openssl-rand-hex-32

# Admin username
ADMIN_USERNAME=admin